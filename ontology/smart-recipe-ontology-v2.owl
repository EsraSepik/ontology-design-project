  <rdf:Description rdf:about="https://example.org/sro#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dcterms:title xml:lang="en">Smart Recipe Ontology (SRO)</dcterms:title>
    <dcterms:creator xml:lang="en">Aleyna Gultekin 220315013</dcterms:creator>
    <dcterms:creator xml:lang="en">Esra Sepik 220315015</dcterms:creator>
    <dcterms:creator xml:lang="en">Sinem Tanriver 220315073</dcterms:creator>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-25</dcterms:created>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-08</dcterms:modified>
    <owl:versionInfo>2.0</owl:versionInfo>
    <dcterms:description xml:lang="en">Phase 2 extension of the Smart Recipe Ontology. The ontology represents recipes, ingredient usages, preparation steps, dietary tags, nutrition profiles, utilities, cuisine, data provenance, and data-acquisition confidence for recipe search and question answering.</dcterms:description>
    <rdfs:seeAlso rdf:resource="https://schema.org/Recipe"/>
    <rdfs:seeAlso rdf:resource="https://schema.org/NutritionInformation"/>
    <rdfs:seeAlso rdf:resource="http://qudt.org/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/sro#usesIngredient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">uses ingredient</rdfs:label>
    <rdfs:domain rdf:resource="https://example.org/sro#IngredientUsage"/>
    <rdfs:range rdf:resource="https://example.org/sro#Ingredient"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/sro#hasCourseCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has course category</rdfs:label>
    <rdfs:domain rdf:resource="https://example.org/sro#Recipe"/>
    <rdfs:range rdf:resource="https://example.org/sro#CourseCategory"/>
    <rdfs:seeAlso rdf:resource="https://schema.org/recipeCategory"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/sro#Spinach">
    <rdf:type rdf:resource="https://example.org/sro#PlantBasedIngredient"/>
    <rdfs:label xml:lang="en">spinach</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/sro#ChickpeaSalad_Step3">
