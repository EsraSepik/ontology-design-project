    <sro:instructionText xml:lang="en">Mix and serve chilled.</sro:instructionText>
    <sro:requiresUtility rdf:resource="https://example.org/sro#MixingBowl"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/sro#Omelette_SpinachUsage">
